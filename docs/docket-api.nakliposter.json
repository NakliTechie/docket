            "url": "{{base_url}}/api/v1/categories/1/toggle_auto_resolve"
          }
        },
        {
          "name": "List SLA policies",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/sla_policies"
          }
        },
        {
          "name": "Create SLA policy with targets",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/sla_policies",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
