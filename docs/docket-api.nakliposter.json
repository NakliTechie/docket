              "raw": "{\n  \"sla_policy\": {\n    \"name\": \"Standard service\",\n    \"sla_targets_attributes\": [\n      { \"priority\": \"normal\", \"first_response_minutes\": 120, \"resolution_minutes\": 2880 },\n      { \"priority\": \"urgent\", \"first_response_minutes\": 15, \"resolution_minutes\": 240 }\n    ]\n  }\n}"
