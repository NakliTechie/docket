            "url": "{{base_url}}/api/v1/users"
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
