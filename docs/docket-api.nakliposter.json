    {
      "name": "Webhooks",
      "item": [
        {
          "name": "List endpoints",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/webhook_endpoints"
          }
        },
        {
          "name": "Create endpoint (signing secret shown once)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/webhook_endpoints",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"webhook_endpoint\": {\n    \"name\": \"Branch CRM\",\n    \"url\": \"https://crm.example.in/hooks/docket\",\n    \"events\": [\"case.created\", \"case.status_changed\", \"case.message_added\", \"case.sla_breached\", \"case.resolved\"]\n  }\n}"
            }
          }
        },
        {
          "name": "Delivery log",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/webhook_endpoints/1/deliveries"
          }
        }
      ]
    },
    {
      "name": "Webhook receiver test",
      "description": "Simulates Docket delivering a signed event to YOUR receiver so you can verify signature handling end-to-end. Point receiver_url at your endpoint; the pre-request script computes X-Docket-Signature exactly as Docket does: 'sha256=' + HMAC_SHA256(endpoint_secret, raw_body).",
      "item": [
        {
          "name": "Deliver signed sample event to your receiver",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const body = JSON.stringify({",
                  "  event: 'case.created',",
                  "  occurred_at: new Date().toISOString(),",
                  "  data: { id: 1, tracking_id: 'DKT-SAMP-LE42', subject: 'Signature test', status: 'new',",
                  "          priority: 'normal', channel: 'api', contact: { id: 1, external_id: 'CIF447192' } }",
                  "});",
                  "pm.collectionVariables.set('webhook_sample_body', body);",
                  "const sig = CryptoJS.HmacSHA256(body, pm.collectionVariables.get('webhook_secret'));",
                  "pm.collectionVariables.set('webhook_signature', 'sha256=' + sig.toString(CryptoJS.enc.Hex));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('receiver accepted the signed event', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{receiver_url}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "User-Agent",
                "value": "Docket-Webhook"
              },
              {
                "key": "X-Docket-Event",
                "value": "case.created"
              },
              {
                "key": "X-Docket-Delivery",
                "value": "sample-1"
              },
              {
                "key": "X-Docket-Signature",
                "value": "{{webhook_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhook_sample_body}}"
            }
          }
        }
      ]
    }
  ]
}