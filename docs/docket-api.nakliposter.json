{
  "info": {
    "name": "Docket API v1",
    "description": "Full Docket API surface. Set base_url, then either user_token (per-user, console-parity) or run 'OAuth · client credentials' to fill access_token (service account, scoped). The 'On-behalf-of flow' folder shows how an operator system files and reads cases for its own customers by external_id (e.g. bank CIF). The 'Webhook receiver' folder documents signature verification for the signed events Docket POSTs to your systems.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "user_token",
      "value": "dkt_PASTE_YOUR_TOKEN"
    },
    {
      "key": "client_id",
      "value": "svc_PASTE_CLIENT_ID"
    },
    {
      "key": "client_secret",
      "value": "PASTE_CLIENT_SECRET"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "case_id",
      "value": "1"
    },
    {
      "key": "tracking_id",
      "value": "DKT-XXXX-XXXX"
    },
    {
      "key": "external_id",
      "value": "CIF447192"
    },
    {
      "key": "webhook_secret",
      "value": "whsec_PASTE_ENDPOINT_SECRET"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{user_token}}"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "OAuth · client credentials (M2M)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('access_token', data.access_token);",
                  "pm.test('token issued', () => pm.expect(data.access_token).to.match(/^dkts_/));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{base_url}}/api/v1/oauth/token",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}"
                }
              ]
            }
          }
        },
        {
          "name": "OpenAPI spec",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{base_url}}/api/v1/openapi.json"
          }
        }
      ]
    },
    {
      "name": "Cases",
      "item": [
        {
          "name": "List cases (filters: q, status, priority, queue_id, assignee_id, contact_external_id)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/cases?status=in_progress&page=1"
          }
        },
        {
          "name": "Show case (by id or tracking ID, include=messages)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/cases/{{tracking_id}}?include=messages"
          }
        },
        {
          "name": "Create case (staff/user token)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case\": {\n    \"subject\": \"Pension not credited\",\n    \"contact_id\": 1,\n    \"priority\": \"high\",\n    \"queue_id\": 1,\n    \"message_body\": \"Citizen reports missing pension credit for May.\"\n  }\n}"
            }
          }
        },
        {
          "name": "Update case",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case\": { \"priority\": \"urgent\", \"queue_id\": 2 }\n}"
            }
          }
        },
        {
          "name": "Transition status (state machine)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/transition",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"status\": \"triaged\" }"
            }
          }
        },
        {
          "name": "Assign / unassign",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/assign",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"assignee_id\": 2 }"
            }
          }
        },
        {
          "name": "List messages",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/messages"
          }
        },
        {
          "name": "Add message (public_reply | internal_note)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/messages",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": { \"body\": \"We are looking into this.\", \"kind\": \"public_reply\" }\n}"
            }
          }
        },
        {
          "name": "Add message with base64 attachment",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/messages",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": {\n    \"body\": \"Photo of the issue attached.\",\n    \"kind\": \"public_reply\",\n    \"attachments\": [\n      {\n        \"filename\": \"evidence.png\",\n        \"content_type\": \"image/png\",\n        \"data\": \"<base64-encoded file bytes>\"\n      }\n    ]\n  }\n}"
            }
          }
        },
        {
          "name": "Delete case (soft)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}"
          }
        },
        {
          "name": "AI · summarise thread",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/assist/summarise"
          }
        },
        {
          "name": "AI · suggest reply",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/assist/suggest_reply"
          }
        }
      ]
    },
    {
      "name": "On-behalf-of flow (service account)",
      "description": "Machine-to-machine attribution: a scoped service account (cases:write + contacts:write) files and reads cases for a customer identified by your own external_id (CIF). Docket upserts/links the Contact and threads everything under their 360. Run 'OAuth · client credentials' first.",
      "item": [
        {
          "name": "1 · File case on behalf of CIF",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            },
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"on_behalf_of\": \"{{external_id}}\",\n  \"contact\": { \"name\": \"Ravi Kumar\", \"email\": \"ravi@example.com\", \"phone\": \"+919876543210\" },\n  \"case\": {\n    \"subject\": \"Card blocked after 3 wrong PINs\",\n    \"message_body\": \"Filed from netbanking: customer requests unblock.\"\n  }\n}"
            }
          }
        },
        {
          "name": "2 · Customer's case list by CIF",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/api/v1/cases?contact_external_id={{external_id}}"
          }
        },
        {
          "name": "3 · Customer replies via your app",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            },
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/{{case_id}}/messages",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"on_behalf_of\": \"{{external_id}}\",\n  \"message\": { \"body\": \"Sent from the mobile app: please expedite.\" }\n}"
            }
          }
        },
        {
          "name": "4 · Contact 360 by CIF",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}"
                }
              ]
            },
            "method": "GET",
            "url": "{{base_url}}/api/v1/contacts/ext:{{external_id}}"
          }
        }
      ]
    },
    {
      "name": "Contacts & Organisations",
      "item": [
        {
          "name": "List/search contacts",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/contacts?q=ravi"
          }
        },
        {
          "name": "Create contact",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/contacts",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact\": { \"name\": \"Asha Rao\", \"email\": \"asha@example.com\", \"external_id\": \"CIF000111\" }\n}"
            }
          }
        },
        {
          "name": "Show contact by external id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/contacts/ext:{{external_id}}"
          }
        },
        {
          "name": "List organisations",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/organisations"
          }
        },
        {
          "name": "Create organisation",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/organisations",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organisation\": { \"name\": \"Karol Bagh Branch\", \"kind\": \"branch\", \"external_ref\": \"KB001\" }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Configuration",
      "item": [
        {
          "name": "List queues",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/queues"
          }
        },
        {
          "name": "Create queue",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/queues",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"queue\": { \"name\": \"Card disputes\" } }"
            }
          }
        },
        {
          "name": "List categories",
          "request": {
            "method": "GET",
