{
  "realm": "docket-test",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "users": [
    {
      "username": "staff.user",
      "email": "staff.sso@example.com",
      "firstName": "Staff",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [ { "type": "password", "value": "staffpass", "temporary": false } ],
      "groups": [ "docket-admins" ]
    },
    {
      "username": "customer.user",
      "email": "customer.sso@example.com",
      "firstName": "Customer",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [ { "type": "password", "value": "customerpass", "temporary": false } ],
      "attributes": { "cif": [ "CIF555123" ] }
    }
  ],
  "groups": [ { "name": "docket-admins" } ],
  "clients": [
    {
      "clientId": "docket-staff",
      "secret": "staff-client-secret",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "redirectUris": [ "http://localhost:3001/auth/staff_oidc/callback" ],
      "defaultClientScopes": [ "openid", "email", "profile", "groups" ]
    },
    {
      "clientId": "docket-customer",
      "secret": "customer-client-secret",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "redirectUris": [ "http://localhost:3001/auth/customer_oidc/callback" ],
      "defaultClientScopes": [ "openid", "email", "profile", "cif" ]
    }
  ],
  "clientScopes": [
    {
      "name": "groups",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": { "claim.name": "groups", "full.path": "false",
                      "id.token.claim": "true", "userinfo.token.claim": "true" }
        }
      ]
    },
    {
      "name": "cif",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "cif",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": { "user.attribute": "cif", "claim.name": "cif",
                      "id.token.claim": "true", "userinfo.token.claim": "true" }
        }
      ]
    }
  ]
}
