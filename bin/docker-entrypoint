#!/bin/bash -e

# Secret key base: never ship a usable default (a known key in a public
# repo lets anyone forge session cookies and reset tokens). If the
# operator hasn't supplied one, generate a unique key and persist it to
# the storage volume so it's stable across restarts but per-deployment.
# Done before any Rails command, which needs it to boot in production.
if [ -z "${SECRET_KEY_BASE}" ]; then
  SECRET_KEY_FILE="/rails/storage/secret_key_base"
  if [ ! -f "${SECRET_KEY_FILE}" ]; then
    ruby -rsecurerandom -e 'print SecureRandom.hex(64)' > "${SECRET_KEY_FILE}"
    chmod 600 "${SECRET_KEY_FILE}"
    echo "Generated a unique SECRET_KEY_BASE (persisted to storage volume)."
  fi
  export SECRET_KEY_BASE="$(cat "${SECRET_KEY_FILE}")"
fi

# If running the rails server then prepare all databases (primary +
# cache + queue + cable) and optionally load the demo seed data.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  if [ "${DOCKET_SEED_DEMO}" == "true" ]; then
    ./bin/rails db:seed demo:seed
  else
    ./bin/rails db:seed
  fi
fi

exec "${@}"
