<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(CaseQueue).create? %>
      <%= link_to new_case_queue_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_queue") %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @queues.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.slug") %></th>
          <th><%= t(".columns.members") %></th>
          <th><%= t(".columns.open_cases") %></th>
          <th class="actions"><%= t("tables.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @queues.each do |queue| %>
          <tr>
            <td><%= queue.name %></td>
            <td class="mono"><%= queue.slug %></td>
            <td><%= queue.members.map(&:name).join(", ").presence || tag.span(t(".no_members"), class: "muted") %></td>
            <td><%= link_to queue.cases.open_cases.count, cases_path(queue_id: queue.id) %></td>
            <td class="actions">
              <% if policy(queue).update? %>
                <%= link_to t("actions.edit"), edit_case_queue_path(queue), class: "btn btn-sm" %>
              <% end %>
              <% if policy(queue).destroy? %>
                <%= button_to t("actions.delete"), case_queue_path(queue), method: :delete, class: "btn btn-sm btn-danger",
                      form: { class: "inline-form", data: { turbo_confirm: t(".confirm_delete") } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state",
        title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(CaseQueue).create? ? link_to(t(".new_queue"), new_case_queue_path, class: "btn btn-primary") : nil %>
<% end %>
