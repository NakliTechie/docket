<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(Organisation).create? %>
      <%= link_to new_organisation_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_organisation") %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @organisations.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.kind") %></th>
          <th><%= t(".columns.external_ref") %></th>
          <th class="actions"><%= t("tables.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @organisations.each do |organisation| %>
          <tr>
            <td><%= link_to organisation.name, organisation_path(organisation) %></td>
            <td><%= organisation.human_kind %></td>
            <td class="mono"><%= organisation.external_ref %></td>
            <td class="actions">
              <% if policy(organisation).update? %>
                <%= link_to t("actions.edit"), edit_organisation_path(organisation), class: "btn btn-sm" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <%= render "shared/empty_state",
        title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(Organisation).create? ? link_to(t(".new_organisation"), new_organisation_path, class: "btn btn-primary") : nil %>
<% end %>
