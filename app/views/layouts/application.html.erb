<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="referrer" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <a class="skip-link" href="#main"><%= t("layout.skip_to_content") %></a>

    <% if authenticated? %>
      <header class="app-header">
        <nav class="app-nav" aria-label="<%= t("layout.primary_navigation") %>">
          <%= link_to t("layout.product_name"), root_path, class: "brand" %>
          <%= nav_link t("layout.nav.cases"), cases_path, active: controller_name == "cases" %>
          <%= nav_link t("layout.nav.contacts"), contacts_path, active: controller_name == "contacts" %>
          <%= nav_link t("layout.nav.organisations"), organisations_path, active: controller_name == "organisations" %>
          <% if policy(CaseQueue).create? %>
            <%= nav_link t("layout.nav.queues"), case_queues_path, active: controller_name == "case_queues" %>
            <%= nav_link t("layout.nav.categories"), categories_path, active: controller_name == "categories" %>
            <%= nav_link t("layout.nav.sla_policies"), sla_policies_path, active: controller_name == "sla_policies" %>
          <% end %>
          <% if policy(User).index? %>
            <%= nav_link t("layout.nav.users"), admin_users_path, active: controller_name == "users" %>
          <% end %>
        </nav>
        <div class="app-header-right">
          <%= button_to t("layout.locale_switch_label"), locale_path(locale: I18n.locale == :en ? "hi" : "en"),
                        class: "btn btn-ghost btn-sm", form: { class: "inline-form" } %>
          <span class="current-user"><%= Current.user.name %> · <%= role_badge(Current.user) %></span>
          <%= button_to t("layout.sign_out"), session_path, method: :delete,
                        class: "btn btn-ghost btn-sm", form: { class: "inline-form" } %>
        </div>
      </header>
    <% end %>

    <main id="main" class="app-main">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
