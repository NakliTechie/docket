<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="referrer" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>
  </head>

  <body <%= "data-controller=hotkeys" if authenticated? %>>
    <a class="skip-link" href="#main"><%= t("layout.skip_to_content") %></a>

    <% if authenticated? %>
      <header class="app-header">
        <nav class="app-nav" aria-label="<%= t("layout.primary_navigation") %>">
          <%= link_to brand_name, root_path, class: "brand" %>
          <%= nav_link t("layout.nav.cases"), cases_path, active: controller_name == "cases" %>
          <% if policy(:dashboard).index? %>
            <%= nav_link t("layout.nav.dashboard"), dashboard_path, active: controller_name == "dashboards" %>
          <% end %>

          <%= nav_group t("layout.nav.crm"),
                active: %w[contacts organisations leads deals pipelines sequences sales_reports].include?(controller_name) do %>
            <%= nav_link t("layout.nav.contacts"), contacts_path, active: controller_name == "contacts" %>
            <%= nav_link t("layout.nav.organisations"), organisations_path, active: controller_name == "organisations" %>
            <%= nav_link t("layout.nav.leads"), leads_path, active: controller_name == "leads" %>
            <%= nav_link t("layout.nav.deals"), deals_path, active: controller_name == "deals" %>
            <%= nav_link t("layout.nav.sales_report"), sales_report_path, active: controller_name == "sales_reports" %>
            <% if policy(Pipeline).create? %>
              <%= nav_link t("layout.nav.pipelines"), pipelines_path, active: controller_name == "pipelines" %>
              <%= nav_link t("layout.nav.sequences"), sequences_path, active: controller_name == "sequences" %>
            <% end %>
          <% end %>

          <% if policy(CaseQueue).create? || policy(ReferenceDoc).index? || policy(ConnectorInvocation).index? %>
            <%= nav_group t("layout.nav.service_desk"),
                  active: %w[case_queues categories sla_policies macros reference_docs connector_invocations decision_appeals].include?(controller_name) do %>
              <% if policy(CaseQueue).create? %>
                <%= nav_link t("layout.nav.queues"), case_queues_path, active: controller_name == "case_queues" %>
                <%= nav_link t("layout.nav.categories"), categories_path, active: controller_name == "categories" %>
                <%= nav_link t("layout.nav.sla_policies"), sla_policies_path, active: controller_name == "sla_policies" %>
                <%= nav_link t("layout.nav.macros"), macros_path, active: controller_name == "macros" %>
              <% end %>
              <% if policy(ReferenceDoc).index? %>
                <%= nav_link t("layout.nav.reference_docs"), admin_reference_docs_path, active: controller_name == "reference_docs" %>
              <% end %>
              <% if policy(ConnectorInvocation).index? %>
                <%= nav_link t("layout.nav.agent_actions"), admin_connector_invocations_path, active: controller_name == "connector_invocations" %>
              <% end %>
              <% if policy(DecisionAppeal).index? %>
                <%= nav_link t("layout.nav.decision_appeals"), admin_decision_appeals_path, active: controller_name == "decision_appeals" %>
              <% end %>
            <% end %>
          <% end %>

          <% if policy(User).index? %>
            <%= nav_group t("layout.nav.admin"),
                  active: %w[users roles tenants activity audit security_events service_accounts api_tokens webhook_endpoints connectors shared_credentials settings].include?(controller_name) do %>
              <%= nav_link t("layout.nav.users"), admin_users_path, active: controller_name == "users" %>
              <%= nav_link t("layout.nav.roles"), admin_roles_path, active: controller_name == "roles" %>
              <% if policy(Tenant).index? %>
                <%= nav_link t("layout.nav.tenants"), admin_tenants_path, active: controller_name == "tenants" %>
              <% end %>
              <%= nav_link t("layout.nav.activity"), admin_activity_path, active: controller_name == "activity" %>
              <%= nav_link t("layout.nav.audit"), admin_audit_path, active: controller_name == "audit" %>
              <%= nav_link t("layout.nav.security_events"), admin_security_events_path, active: controller_name == "security_events" %>
              <%= nav_link t("layout.nav.integrations"), admin_service_accounts_path,
                    active: %w[service_accounts api_tokens webhook_endpoints].include?(controller_name) %>
              <%= nav_link t("layout.nav.connectors"), admin_connectors_path,
                    active: %w[connectors shared_credentials].include?(controller_name) %>
              <%= nav_link t("layout.nav.settings"), admin_settings_path, active: controller_name == "settings" %>
            <% end %>
          <% end %>
        </nav>
        <div class="app-header-right">
          <button type="button" class="btn btn-ghost btn-sm" data-action="hotkeys#openHelp"
                  aria-haspopup="dialog" aria-controls="help-modal">
            <%= icon "help" %><span class="visually-hidden"><%= t("help.title") %></span>
          </button>
          <%= button_to t("layout.locale_switch_label"), locale_path(locale: I18n.locale == :en ? "hi" : "en"),
                        class: "btn btn-ghost btn-sm", form: { class: "inline-form" } %>
          <span class="current-user"><%= Current.user.name %> · <%= role_badge(Current.user) %></span>
          <%= button_to t("layout.sign_out"), session_path, method: :delete,
                        class: "btn btn-ghost btn-sm", form: { class: "inline-form" } %>
        </div>
      </header>
    <% end %>

    <main id="main" class="app-main">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <% if authenticated? %>
      <%= render "shared/help_modal" %>
      <%= render "shared/command_palette" %>
    <% end %>
  </body>
</html>
