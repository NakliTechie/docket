<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="referrer" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <a class="skip-link" href="#main"><%= t("layout.skip_to_content") %></a>

    <header class="app-header">
      <nav class="app-nav" aria-label="<%= t("layout.primary_navigation") %>">
        <span class="brand"><%= t("portal.brand") %></span>
        <%= nav_link t("portal.nav.new_case"), portal_root_path,
              active: controller_name == "cases" %>
        <%= nav_link t("portal.nav.track"), portal_track_path,
              active: controller_name == "tracking" %>
      </nav>
      <div class="app-header-right">
        <%= button_to t("layout.locale_switch_label"), locale_path(locale: I18n.locale == :en ? "hi" : "en"),
              class: "btn btn-ghost btn-sm", form: { class: "inline-form" } %>
      </div>
    </header>

    <main id="main" class="app-main portal-main">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <footer class="portal-footer">
      <p class="muted"><%= t("portal.footer") %></p>
    </footer>
  </body>
</html>
