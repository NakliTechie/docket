<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(Sequence).create? %>
      <%= link_to new_sequence_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_sequence") %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @sequences.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.steps") %></th>
          <th><%= t(".columns.active") %></th>
        </tr>
      </thead>
      <tbody>
        <% @sequences.each do |sequence| %>
          <tr>
            <td><%= link_to sequence.name, sequence_path(sequence) %></td>
            <td><%= sequence.sequence_steps.size %></td>
            <td><%= sequence.active? ? t("forms.yes") : t("forms.no") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state", title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(Sequence).create? ? link_to(t(".new_sequence"), new_sequence_path, class: "btn btn-primary") : nil %>
<% end %>
