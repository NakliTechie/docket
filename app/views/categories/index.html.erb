<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(Category).create? %>
      <%= link_to new_category_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_category") %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @categories.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.description") %></th>
          <th><%= t(".columns.ai_auto_resolve") %></th>
          <th class="actions"><%= t("tables.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @categories.each do |category| %>
          <tr>
            <td><%= category.name %></td>
            <td><%= category.description %></td>
            <td>
              <% if category.ai_auto_resolve %>
                <span class="badge badge-sla sla-overdue"><%= t(".auto_resolve_on") %></span>
              <% else %>
                <span class="muted"><%= t(".auto_resolve_off") %></span>
              <% end %>
            </td>
            <td class="actions">
              <% if policy(category).update? %>
                <%= link_to t("actions.edit"), edit_category_path(category), class: "btn btn-sm" %>
              <% end %>
              <% if policy(category).destroy? %>
                <%= button_to t("actions.delete"), category_path(category), method: :delete, class: "btn btn-sm btn-danger",
                      form: { class: "inline-form", data: { turbo_confirm: t(".confirm_delete") } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state",
        title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(Category).create? ? link_to(t(".new_category"), new_category_path, class: "btn btn-primary") : nil %>
<% end %>
