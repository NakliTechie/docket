<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(Pipeline).create? %>
      <%= link_to new_pipeline_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_pipeline") %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @pipelines.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.stages") %></th>
          <th><%= t(".columns.active") %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @pipelines.each do |pipeline| %>
          <tr>
            <td><%= pipeline.name %></td>
            <td><%= pipeline.pipeline_stages.sort_by(&:position).map(&:name).join(" → ") %></td>
            <td><%= pipeline.active? ? t("forms.yes") : t("forms.no") %></td>
            <td>
              <% if policy(pipeline).update? %>
                <%= link_to t("actions.edit"), edit_pipeline_path(pipeline), class: "btn btn-sm" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state", title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(Pipeline).create? ? link_to(t(".new_pipeline"), new_pipeline_path, class: "btn btn-primary") : nil %>
<% end %>
