<%= form_with model: process, url: process.persisted? ? approval_process_path(process) : approval_processes_path,
      scope: :approval_process, class: "form" do |f| %>
  <%= render "shared/form_errors", record: process %>

  <div class="form-row <%= "field-error" if process.errors[:name].any? %>">
    <%= f.label :name, t("approval_processes.fields.name") %>
    <%= f.text_field :name, required: true %>
    <% process.errors[:name].each do |msg| %><p class="field-error-message"><%= msg %></p><% end %>
  </div>

  <div class="form-row">
    <%= f.label :trigger_type, t("approval_processes.fields.trigger_type") %>
    <%= f.select :trigger_type,
          ApprovalProcess.trigger_types.keys.map { |t| [ t("approval_processes.enum.trigger_type.#{t}"), t ] } %>
    <p class="form-hint"><%= t("approval_processes.form.trigger_type_hint") %></p>
  </div>

  <div class="form-row <%= "field-error" if process.errors[:trigger_key].any? %>">
    <%= f.label :trigger_key, t("approval_processes.fields.trigger_key") %>
    <%= f.text_field :trigger_key, required: true %>
    <p class="form-hint"><%= t("approval_processes.form.trigger_key_hint", statuses: Case.statuses.keys.join(", ")) %></p>
    <% process.errors[:trigger_key].each do |msg| %><p class="field-error-message"><%= msg %></p><% end %>
  </div>

  <div class="form-row">
    <label class="checkbox-row">
      <%= f.check_box :active %>
      <%= t("approval_processes.fields.active") %>
    </label>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), approval_processes_path, class: "btn" %>
  </div>
<% end %>
