<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(ApprovalProcess).create? %>
      <%= link_to new_approval_process_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_process") %>
      <% end %>
    <% end %>
  </div>
</div>

<p class="page-intro"><%= t(".intro") %></p>

<% if @processes.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.trigger") %></th>
          <th><%= t(".columns.status") %></th>
          <th class="actions"><%= t("tables.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @processes.each do |process| %>
          <tr class="<%= "muted-row" unless process.active %>">
            <td><%= process.name %></td>
            <td>
              <%= t("approval_processes.enum.trigger_type.#{process.trigger_type}") %>:
              <span class="mono"><%= process.trigger_key %></span>
            </td>
            <td>
              <% if process.active %>
                <span class="badge badge-success"><%= t(".active") %></span>
              <% else %>
                <span class="badge"><%= t(".inactive") %></span>
              <% end %>
            </td>
            <td class="actions">
              <% if policy(process).update? %>
                <%= link_to t("actions.edit"), edit_approval_process_path(process), class: "btn btn-sm" %>
              <% end %>
              <% if policy(process).destroy? %>
                <%= button_to t("actions.delete"), approval_process_path(process), method: :delete, class: "btn btn-sm btn-danger",
                      form: { class: "inline-form", data: { turbo_confirm: t(".confirm_delete") } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state",
        title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(ApprovalProcess).create? ? link_to(t(".new_process"), new_approval_process_path, class: "btn btn-primary") : nil %>
<% end %>
