<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
</div>

<%= form_with model: @tenant, url: admin_tenants_path, class: "form" do |f| %>
  <div class="form-row">
    <%= f.label :name, t(".fields.name") %>
    <%= f.text_field :name, required: true %>
  </div>

  <div class="form-row">
    <%= f.label :subdomain, t(".fields.subdomain") %>
    <%= f.text_field :subdomain, required: true %>
    <p class="form-hint"><%= t(".subdomain_hint") %></p>
  </div>

  <div class="form-row">
    <%= f.label :admin_email, t(".fields.admin_email") %>
    <%= f.email_field :admin_email %>
    <p class="form-hint"><%= t(".admin_email_hint") %></p>
  </div>

  <div class="form-actions">
    <%= f.submit t(".submit"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), admin_tenants_path, class: "btn" %>
  </div>
<% end %>
