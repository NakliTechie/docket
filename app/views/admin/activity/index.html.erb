<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <%= link_to t(".export_csv"), admin_activity_path(format: :csv, from: @from, to: @to), class: "btn" %>
  </div>
</div>

<p class="muted"><%= t(".sovereignty_note") %></p>

<%= form_with url: admin_activity_path, method: :get, class: "filter-bar" do |f| %>
  <div class="form-row">
    <%= f.label :from, t(".from") %>
    <%= f.date_field :from, value: @from %>
  </div>
  <div class="form-row">
    <%= f.label :to, t(".to") %>
    <%= f.date_field :to, value: @to %>
  </div>
  <%= f.submit t("filters.apply"), class: "btn" %>
<% end %>

<div class="panel">
  <h2 class="panel-title"><%= t(".summary") %></h2>
  <dl class="meta-list">
    <dt><%= t(".cases_created") %></dt><dd><%= @report.stats[:cases_created] %></dd>
    <dt><%= t(".cases_resolved") %></dt><dd><%= @report.stats[:cases_resolved] %></dd>
    <dt><%= t(".resolution_rate") %></dt>
    <dd><%= @report.stats[:resolution_rate] ? t(".percent", value: @report.stats[:resolution_rate]) : "—" %></dd>
    <dt><%= t(".sla_breaches") %></dt><dd><%= @report.stats[:sla_breaches] %></dd>
    <dt><%= t(".sla_compliance") %></dt>
    <dd><%= @report.stats[:sla_compliance] ? t(".percent", value: @report.stats[:sla_compliance]) : "—" %></dd>
    <dt><%= t(".agent_vs_human") %></dt>
    <dd><%= t(".agent_vs_human_value", agent: @report.stats[:agent_turns], human: @report.stats[:human_replies]) %></dd>
  </dl>
</div>

<div class="two-column">
  <section>
    <div class="panel">
      <h2 class="panel-title"><%= t(".per_user_actions") %></h2>
      <% if @report.actions_by_user.any? %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th><%= t(".columns.user") %></th>
                <th><%= t(".columns.action") %></th>
                <th><%= t(".columns.count") %></th>
              </tr>
            </thead>
            <tbody>
              <% @report.actions_by_user.each do |user_id, actions| %>
                <% actions.sort_by { |_, c| -c }.each_with_index do |(action, count), i| %>
                  <tr>
                    <td><%= i.zero? ? (@report.users[user_id]&.name || t(".deleted_user")) : "" %></td>
                    <td class="mono"><%= action %></td>
                    <td><%= count %></td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="muted"><%= t(".no_activity") %></p>
      <% end %>
    </div>

    <div class="panel">
      <h2 class="panel-title"><%= t(".login_history") %></h2>
      <% if @report.logins.any? %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th><%= t(".columns.user") %></th>
                <th><%= t(".columns.method") %></th>
                <th><%= t(".columns.ip") %></th>
                <th><%= t(".columns.when") %></th>
              </tr>
            </thead>
            <tbody>
              <% @report.logins.each do |entry| %>
                <tr>
                  <td><%= entry.actor.respond_to?(:name) ? entry.actor.name : t(".deleted_user") %></td>
                  <td class="mono"><%= entry.action %></td>
                  <td class="mono"><%= entry.metadata&.dig("ip") %></td>
                  <td class="table-meta"><%= l entry.created_at, format: :short %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="muted"><%= t(".no_logins") %></p>
      <% end %>
    </div>
  </section>

  <aside>
    <div class="panel">
      <h2 class="panel-title"><%= t(".volume_by_queue") %></h2>
      <% if @report.volume_by_queue.any? %>
        <dl class="meta-list">
          <% @report.volume_by_queue.sort_by { |_, c| -c }.each do |queue, count| %>
            <dt><%= queue&.name || t("cases.no_queue") %></dt><dd><%= count %></dd>
          <% end %>
        </dl>
      <% else %>
        <p class="muted"><%= t(".no_activity") %></p>
      <% end %>
    </div>

    <div class="panel">
      <h2 class="panel-title"><%= t(".volume_by_staff") %></h2>
      <% if @report.volume_by_staff.any? %>
        <dl class="meta-list">
          <% @report.volume_by_staff.sort_by { |_, c| -c }.each do |user, count| %>
            <dt><%= user&.name || t(".deleted_user") %></dt><dd><%= count %></dd>
          <% end %>
        </dl>
      <% else %>
        <p class="muted"><%= t(".no_activity") %></p>
      <% end %>
    </div>
  </aside>
</div>
