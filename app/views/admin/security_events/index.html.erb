<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
</div>

<p class="muted"><%= t(".intro") %></p>

<% if @events.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.when") %></th>
          <th><%= t(".columns.kind") %></th>
          <th><%= t(".columns.email") %></th>
          <th><%= t(".columns.ip") %></th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr>
            <td><%= l event.created_at, format: :long %></td>
            <td><span class="badge"><%= t("admin.security_events.kinds.#{event.kind}", default: event.kind) %></span></td>
            <td><%= event.email %></td>
            <td class="mono"><%= event.ip_address %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <p class="muted"><%= t(".empty") %></p>
<% end %>
