<% page_title @user.name %>
<div class="page-header">
  <h1><%= @user.name %></h1>
  <div class="page-actions">
    <%= link_to t("actions.edit"), edit_admin_user_path(@user), class: "btn" %>
  </div>
</div>

<div class="two-column">
  <section>
    <div class="panel">
      <h2 class="panel-title"><%= t(".recent_activity") %></h2>
      <% if @recent_actions.any? %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th><%= t(".columns.action") %></th>
                <th><%= t(".columns.subject") %></th>
                <th><%= t(".columns.when") %></th>
              </tr>
            </thead>
            <tbody>
              <% @recent_actions.each do |entry| %>
                <tr>
                  <td class="mono"><%= entry.action %></td>
                  <td class="table-meta"><%= entry.auditable_type %> #<%= entry.auditable_id %></td>
                  <td class="table-meta"><%= l entry.created_at, format: :short %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="muted"><%= t(".no_activity") %></p>
      <% end %>
    </div>
  </section>

  <aside>
    <div class="panel">
      <h2 class="panel-title"><%= t(".details") %></h2>
      <dl class="meta-list">
        <dt><%= t("admin.users.fields.email") %></dt><dd><%= @user.email_address %></dd>
        <dt><%= t("admin.users.fields.role") %></dt><dd><%= role_badge(@user) %></dd>
        <dt><%= t("admin.users.fields.queues") %></dt><dd><%= @user.queues.map(&:name).join(", ").presence || "—" %></dd>
        <dt><%= t(".member_since") %></dt><dd><%= l @user.created_at, format: :long %></dd>
      </dl>
    </div>
  </aside>
</div>
