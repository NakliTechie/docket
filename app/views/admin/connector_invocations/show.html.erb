<% page_title t(".title", id: @invocation.id) %>
<div class="page-header">
  <h1><%= t(".title", id: @invocation.id) %></h1>
  <div class="page-actions">
    <% if @invocation.awaiting_approval? %>
      <%= button_to t(".approve"), approve_admin_connector_invocation_path(@invocation),
            class: "btn btn-primary",
            form: { data: { turbo_confirm: t(".approve_confirm") } } %>
      <%= button_to t(".reject"), reject_admin_connector_invocation_path(@invocation),
            class: "btn btn-danger",
            form: { data: { turbo_confirm: t(".reject_confirm") } } %>
    <% end %>
    <%= link_to t(".back"), admin_connector_invocations_path, class: "btn" %>
  </div>
</div>

<div class="panel">
  <dl class="meta-list">
    <dt><%= t(".status") %></dt>
    <dd><span class="badge"><%= t("admin.connector_invocations.status.#{@invocation.status}") %></span></dd>
    <dt><%= t(".connector") %></dt><dd><%= @invocation.connector.name %></dd>
    <dt><%= t(".action") %></dt><dd class="mono"><%= @invocation.action %></dd>
    <dt><%= t(".effect") %></dt>
    <dd><%= t("admin.connector_invocations.effects.#{@invocation.effect}", default: @invocation.effect.to_s) %></dd>
    <dt><%= t(".requested_by") %></dt>
    <dd><%= @invocation.requester_label.presence || t("admin.connector_invocations.index.requested_by_system") %></dd>
    <dt><%= t(".on_behalf_of") %></dt><dd class="mono"><%= @invocation.on_behalf_of.presence || t(".none") %></dd>
    <% if @invocation.approved_by %>
      <dt><%= t(".approved_by") %></dt><dd><%= @invocation.approved_by.name %></dd>
    <% end %>
  </dl>
  <% if @invocation.reasoning.present? %>
    <h2 class="panel-title"><%= t(".reasoning") %></h2>
    <p class="muted"><%= @invocation.reasoning %></p>
  <% end %>
</div>

<div class="panel">
  <h2 class="panel-title"><%= t(".args") %></h2>
  <pre class="mono text-sm"><%= JSON.pretty_generate(@invocation.args || {}) %></pre>
  <% if @invocation.result.present? %>
    <h2 class="panel-title"><%= t(".result") %></h2>
    <pre class="mono text-sm"><%= JSON.pretty_generate(@invocation.result) %></pre>
  <% end %>
  <% if @invocation.error.present? %>
    <h2 class="panel-title"><%= t(".error") %></h2>
    <p class="muted text-sm"><%= @invocation.error %></p>
  <% end %>
</div>
