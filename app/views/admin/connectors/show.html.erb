<% page_title @connector.name %>
<div class="page-header">
  <h1><%= @connector.name %></h1>
  <div class="page-actions">
    <%= button_to t(".sync_now"), sync_admin_connector_path(@connector), class: "btn btn-primary" %>
    <% if @connector.status_active? %>
      <%= button_to t(".pause"), pause_admin_connector_path(@connector), class: "btn" %>
    <% else %>
      <%= button_to t(".resume"), resume_admin_connector_path(@connector), class: "btn" %>
    <% end %>
    <%= link_to t(".edit"), edit_admin_connector_path(@connector), class: "btn" %>
  </div>
</div>

<div class="panel">
  <dl class="meta-list">
    <dt><%= t(".provider") %></dt><dd><%= @connector.provider_descriptor&.name || @connector.provider %></dd>
    <dt><%= t(".target") %></dt><dd><%= @connector.target %></dd>
    <dt><%= t(".status") %></dt><dd><span class="badge"><%= t("admin.connectors.status.#{@connector.status}") %></span></dd>
    <dt><%= t(".schedule") %></dt>
    <dd><%= @connector.schedule_interval_minutes ? t(".every_minutes", count: @connector.schedule_interval_minutes) : t(".manual") %></dd>
    <dt><%= t(".last_synced") %></dt><dd><%= @connector.last_synced_at ? l(@connector.last_synced_at, format: :long) : t(".never") %></dd>
    <dt><%= t(".webhook_url") %></dt><dd class="mono table-meta"><%= connector_webhook_url(@connector) %></dd>
  </dl>
  <p class="muted text-sm"><%= t(".webhook_hint") %></p>
</div>

<div class="panel">
  <h2 class="panel-title"><%= t(".runs") %></h2>
  <% if @runs.any? %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t(".run_columns.when") %></th>
            <th><%= t(".run_columns.trigger") %></th>
            <th><%= t(".run_columns.status") %></th>
            <th><%= t(".run_columns.in") %></th>
            <th><%= t(".run_columns.created") %></th>
            <th><%= t(".run_columns.updated") %></th>
            <th><%= t(".run_columns.error") %></th>
          </tr>
        </thead>
        <tbody>
          <% @runs.each do |run| %>
            <tr>
              <td><%= l run.created_at, format: :long %></td>
              <td><%= t("admin.connectors.triggers.#{run.trigger}") %></td>
              <td><span class="badge"><%= t("admin.connectors.run_status.#{run.status}") %></span></td>
              <td><%= run.records_in %></td>
              <td><%= run.records_created %></td>
              <td><%= run.records_updated %></td>
              <td class="muted text-sm"><%= run.error %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted"><%= t(".no_runs") %></p>
  <% end %>
</div>

<div class="panel">
  <h2 class="panel-title"><%= t(".effector") %></h2>
  <% if @invocations.any? %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t(".invocation_columns.when") %></th>
            <th><%= t(".invocation_columns.action") %></th>
            <th><%= t(".invocation_columns.on_behalf_of") %></th>
            <th><%= t(".invocation_columns.requested_by") %></th>
            <th><%= t(".invocation_columns.status") %></th>
          </tr>
        </thead>
        <tbody>
          <% @invocations.each do |inv| %>
            <tr>
              <td><%= link_to l(inv.created_at, format: :long), admin_connector_invocation_path(inv) %></td>
              <td class="mono"><%= inv.action %></td>
              <td class="mono text-sm"><%= inv.on_behalf_of %></td>
              <td><%= inv.requester_label %></td>
              <td><span class="badge"><%= t("admin.connector_invocations.status.#{inv.status}") %></span></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted"><%= t(".no_invocations") %></p>
  <% end %>
</div>

<%= button_to t(".delete"), admin_connector_path(@connector), method: :delete, class: "btn btn-danger",
      form: { data: { turbo_confirm: t(".delete_confirm") } } %>
