<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
</div>

<div class="panel">
  <h2 class="panel-title"><%= t(".chain_status") %></h2>
  <% if @verification.nil? %>
    <p class="muted"><%= t(".verification_platform_only") %></p>
  <% elsif @verification[:ok] %>
    <p>
      <span class="badge badge-sla sla-ok"><%= icon "shield" %> <%= t(".intact") %></span>
      <%= t(".intact_detail", count: @verification[:count]) %>
    </p>
  <% else %>
    <p>
      <span class="badge badge-sla sla-breached"><%= icon "alert" %> <%= t(".broken") %></span>
      <%= t(".broken_detail", entry_id: @verification[:entry_id], reason: @verification[:reason]) %>
    </p>
    <dl class="meta-list">
      <dt><%= t(".expected") %></dt><dd class="mono"><%= @verification[:expected_sha] %></dd>
      <dt><%= t(".stored") %></dt><dd class="mono"><%= @verification[:stored_sha] %></dd>
    </dl>
  <% end %>
</div>

<div class="panel">
  <h2 class="panel-title"><%= t(".log_summary") %></h2>
  <dl class="meta-list">
    <dt><%= t(".entries") %></dt><dd><%= @entry_count %></dd>
    <% if @latest_entry %>
      <dt><%= t(".latest") %></dt>
      <dd><%= @latest_entry.action %> · <%= l @latest_entry.created_at, format: :long %></dd>
    <% end %>
  </dl>
  <p class="muted"><%= t(".cli_hint") %></p>
</div>
