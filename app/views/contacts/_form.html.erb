<%= form_with model: contact, class: "form" do |f| %>
  <%= render "shared/form_errors", record: contact %>

  <div class="form-row <%= "field-error" if contact.errors[:name].any? %>">
    <%= f.label :name, t("contacts.fields.name") %>
    <%= f.text_field :name, required: true %>
    <% contact.errors[:name].each do |msg| %><p class="field-error-message"><%= msg %></p><% end %>
  </div>

  <div class="form-row <%= "field-error" if contact.errors[:email].any? %>">
    <%= f.label :email, t("contacts.fields.email") %>
    <%= f.email_field :email %>
    <% contact.errors[:email].each do |msg| %><p class="field-error-message"><%= msg %></p><% end %>
  </div>

  <div class="form-row">
    <%= f.label :phone, t("contacts.fields.phone") %>
    <%= f.telephone_field :phone %>
  </div>

  <div class="form-row">
    <label><%= f.check_box :sms_consent %> <%= t("contacts.fields.sms_consent") %></label>
    <p class="form-hint"><%= t("contacts.form.sms_consent_hint") %></p>
  </div>

  <div class="form-row <%= "field-error" if contact.errors[:external_id].any? %>">
    <%= f.label :external_id, t("contacts.fields.external_id") %>
    <%= f.text_field :external_id %>
    <p class="form-hint"><%= t("contacts.form.external_id_hint") %></p>
    <% contact.errors[:external_id].each do |msg| %><p class="field-error-message"><%= msg %></p><% end %>
  </div>

  <div class="form-row">
    <%= f.label :organisation_id, t("contacts.fields.organisation") %>
    <%= f.collection_select :organisation_id, Organisation.order(:name), :id, :name,
          include_blank: t("forms.none") %>
  </div>

  <div class="form-row">
    <%= f.label :preferred_language, t("contacts.fields.preferred_language") %>
    <%= f.select :preferred_language, Contact::LANGUAGES.map { |l| [ t("locales.#{l}"), l ] } %>
  </div>

  <div class="form-row">
    <%= f.label :notes, t("contacts.fields.notes") %>
    <%= f.text_area :notes %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), contacts_path, class: "btn" %>
  </div>
<% end %>
