<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(Contact).create? %>
      <%= link_to new_contact_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_contact") %>
      <% end %>
    <% end %>
  </div>
</div>

<%= form_with url: contacts_path, method: :get, class: "filter-bar" do |f| %>
  <div class="form-row">
    <%= f.label :q, t("filters.search") %>
    <%= f.search_field :q, value: params[:q] %>
  </div>
  <%= f.submit t("filters.apply"), class: "btn" %>
<% end %>

<% if @contacts.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.email") %></th>
          <th><%= t(".columns.phone") %></th>
          <th><%= t(".columns.external_id") %></th>
          <th><%= t(".columns.organisation") %></th>
        </tr>
      </thead>
      <tbody>
        <% @contacts.each do |contact| %>
          <tr>
            <td><%= link_to contact.name, contact_path(contact) %></td>
            <td><%= contact.email %></td>
            <td><%= contact.phone %></td>
            <td class="mono"><%= contact.external_id %></td>
            <td><%= contact.organisation&.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
<% else %>
  <%= render "shared/empty_state",
        title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(Contact).create? ? link_to(t(".new_contact"), new_contact_path, class: "btn btn-primary") : nil %>
<% end %>
