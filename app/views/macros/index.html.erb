<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(Macro).create? %>
      <%= link_to new_macro_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_macro") %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @macros.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.body") %></th>
          <th class="actions"><%= t("tables.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @macros.each do |macro| %>
          <tr>
            <td><%= macro.name %></td>
            <td class="table-meta"><%= macro.body.truncate(120) %></td>
            <td class="actions">
              <% if policy(macro).update? %>
                <%= link_to t("actions.edit"), edit_macro_path(macro), class: "btn btn-sm" %>
              <% end %>
              <% if policy(macro).destroy? %>
                <%= button_to t("actions.delete"), macro_path(macro), method: :delete, class: "btn btn-sm btn-danger",
                      form: { class: "inline-form", data: { turbo_confirm: t(".confirm_delete") } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state",
        title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(Macro).create? ? link_to(t(".new_macro"), new_macro_path, class: "btn btn-primary") : nil %>
<% end %>
