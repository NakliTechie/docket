<% page_title t(".title") %>
<div class="auth-page">
  <p class="auth-brand"><%= brand_name %></p>
  <div class="panel">
    <h1><%= t(".title") %></h1>
    <%= form_with url: passwords_path do |form| %>
      <div class="form-row">
        <%= form.label :email_address, t("sessions.new.email") %>
        <%= form.email_field :email_address, required: true, autofocus: true,
              autocomplete: "username", value: params[:email_address] %>
      </div>
      <div class="form-actions">
        <%= form.submit t(".send_instructions"), class: "btn btn-primary" %>
        <%= link_to t(".back_to_sign_in"), new_session_path %>
      </div>
    <% end %>
  </div>
</div>
