<% page_title t(".title") %>
<div class="auth-page">
  <p class="auth-brand"><%= t("layout.product_name") %></p>
  <div class="panel">
    <h1><%= t(".title") %></h1>
    <%= form_with url: session_path do |form| %>
      <div class="form-row">
        <%= form.label :email_address, t(".email") %>
        <%= form.email_field :email_address, required: true, autofocus: true,
              autocomplete: "username", value: params[:email_address] %>
      </div>
      <div class="form-row">
        <%= form.label :password, t(".password") %>
        <%= form.password_field :password, required: true,
              autocomplete: "current-password", maxlength: 72 %>
      </div>
      <div class="form-actions">
        <%= form.submit t(".sign_in"), class: "btn btn-primary" %>
        <%= link_to t(".forgot_password"), new_password_path %>
      </div>
    <% end %>

    <% if Sso.staff_oidc_enabled? || Sso.staff_saml_enabled? %>
      <hr>
      <div class="stack-sm">
        <% if Sso.staff_oidc_enabled? %>
          <%# data-turbo=false: a Turbo fetch cannot follow the 302 to the cross-origin IdP %>
          <%= button_to t(".sso_oidc"), "/auth/staff_oidc", class: "btn", form: { class: "inline-form", data: { turbo: false } } %>
        <% end %>
        <% if Sso.staff_saml_enabled? %>
          <%= button_to t(".sso_saml"), "/auth/staff_saml", class: "btn", form: { class: "inline-form", data: { turbo: false } } %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
