<%= form_with model: sla_policy, class: "form" do |f| %>
  <%= render "shared/form_errors", record: sla_policy %>

  <div class="form-row <%= "field-error" if sla_policy.errors[:name].any? %>">
    <%= f.label :name, t("sla_policies.fields.name") %>
    <%= f.text_field :name, required: true %>
    <% sla_policy.errors[:name].each do |msg| %><p class="field-error-message"><%= msg %></p><% end %>
  </div>

  <div class="form-row">
    <%= f.label :description, t("sla_policies.fields.description") %>
    <%= f.text_field :description %>
  </div>

  <fieldset>
    <legend><%= t("sla_policies.fields.targets") %></legend>
    <p class="form-hint"><%= t("sla_policies.form.targets_hint") %></p>
    <%= f.fields_for :sla_targets do |tf| %>
      <div class="form-row">
        <strong><%= t("cases.enum.priority.#{tf.object.priority}") %></strong>
        <%= tf.hidden_field :priority %>
        <div class="filter-bar">
          <div class="form-row">
            <%= tf.label :first_response_minutes, t("sla_policies.fields.first_response_minutes") %>
            <%= tf.number_field :first_response_minutes, min: 1 %>
          </div>
          <div class="form-row">
            <%= tf.label :resolution_minutes, t("sla_policies.fields.resolution_minutes") %>
            <%= tf.number_field :resolution_minutes, min: 1 %>
          </div>
        </div>
      </div>
    <% end %>
  </fieldset>

  <div class="form-actions">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), sla_policies_path, class: "btn" %>
  </div>
<% end %>
