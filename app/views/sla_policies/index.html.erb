<% page_title t(".title") %>
<div class="page-header">
  <h1><%= t(".title") %></h1>
  <div class="page-actions">
    <% if policy(SlaPolicy).create? %>
      <%= link_to new_sla_policy_path, class: "btn btn-primary" do %>
        <%= icon "plus" %><%= t(".new_policy") %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @sla_policies.any? %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.targets") %></th>
          <th class="actions"><%= t("tables.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @sla_policies.each do |policy_record| %>
          <tr>
            <td>
              <%= policy_record.name %>
              <% if Setting.get("default_sla_policy_id") == policy_record.id %>
                <span class="badge badge-role"><%= t(".default") %></span>
              <% end %>
            </td>
            <td>
              <% policy_record.sla_targets.sort_by { |t| SlaTarget.priorities[t.priority] }.each do |target| %>
                <span class="badge badge-priority priority-<%= target.priority %>">
                  <%= t("cases.enum.priority.#{target.priority}") %>:
                  <%= t(".target_summary", response: target.first_response_minutes, resolution: target.resolution_minutes) %>
                </span>
              <% end %>
            </td>
            <td class="actions">
              <% if policy(policy_record).update? %>
                <%= link_to t("actions.edit"), edit_sla_policy_path(policy_record), class: "btn btn-sm" %>
              <% end %>
              <% if policy(policy_record).destroy? %>
                <%= button_to t("actions.delete"), sla_policy_path(policy_record), method: :delete, class: "btn btn-sm btn-danger",
                      form: { class: "inline-form", data: { turbo_confirm: t(".confirm_delete") } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "shared/empty_state",
        title: t(".empty.title"), hint: t(".empty.hint"),
        action: policy(SlaPolicy).create? ? link_to(t(".new_policy"), new_sla_policy_path, class: "btn btn-primary") : nil %>
<% end %>
