<% page_title t(".title") %>
<div class="portal-card">
  <h1><%= t(".title") %></h1>
  <p class="muted"><%= t(".intro") %></p>

  <%= form_with model: @submission, url: portal_cases_path, scope: :portal_submission, class: "form" do |f| %>
    <%= render "shared/form_errors", record: @submission %>

    <div class="form-row">
      <%= f.label :name, t(".your_name") %>
      <%= f.text_field :name, required: true, autocomplete: "name" %>
    </div>

    <div class="form-row">
      <%= f.label :email, t(".your_email") %>
      <%= f.email_field :email, autocomplete: "email" %>
      <p class="form-hint"><%= t(".contact_hint") %></p>
    </div>

    <div class="form-row">
      <%= f.label :phone, t(".your_phone") %>
      <%= f.telephone_field :phone, autocomplete: "tel" %>
    </div>

    <div class="form-row">
      <%= f.label :subject, t(".subject") %>
      <%= f.text_field :subject, required: true %>
    </div>

    <div class="form-row">
      <%= f.label :description, t(".description") %>
      <%= f.text_area :description, required: true, rows: 6 %>
    </div>

    <div class="form-row">
      <%= f.label :files, t(".attachments") %>
      <%= f.file_field :files, multiple: true %>
      <p class="form-hint"><%= t(".attachments_hint") %></p>
    </div>

    <div class="form-actions">
      <%= f.submit t(".submit"), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
