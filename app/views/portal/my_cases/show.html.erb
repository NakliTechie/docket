<% page_title @case.tracking_id %>
<div class="portal-card">
  <h1><%= @case.subject %></h1>
  <p class="muted mono"><%= @case.tracking_id %></p>
  <p><%= status_badge(@case) %> <span class="muted"><%= t("portal.tracking.show.filed_on", date: l(@case.created_at, format: :long)) %></span></p>

  <h2><%= t("portal.tracking.show.updates") %></h2>
  <div class="case-thread">
    <% if @messages.any? %>
      <% @messages.each do |message| %>
        <article class="thread-message direction-<%= message.direction %>">
          <div class="thread-message-head">
            <span class="thread-message-author">
              <%= message.direction_inbound? ? t("portal.tracking.show.you") : t("portal.tracking.show.staff_label") %>
            </span>
            <span><%= l message.created_at, format: :short %></span>
          </div>
          <div class="thread-message-body"><%= message.body %></div>
        </article>
      <% end %>
    <% else %>
      <p class="muted"><%= t("portal.tracking.show.no_updates") %></p>
    <% end %>
  </div>

  <% unless @case.status_closed? %>
    <div class="panel composer">
      <h2 class="panel-title"><%= t("portal.tracking.show.reply") %></h2>
      <%= form_with url: reply_portal_my_case_path(@case), class: "form" do |f| %>
        <div class="form-row">
          <%= f.label :body, t("portal.tracking.show.reply_body"), class: "visually-hidden" %>
          <%= f.text_area :body, required: true, placeholder: t("portal.tracking.show.reply_placeholder") %>
        </div>
        <div class="composer-toolbar">
          <div>
            <%= f.label :files, t("portal.cases.new.attachments"), class: "visually-hidden" %>
            <%= f.file_field :files, multiple: true %>
          </div>
          <%= f.submit t("portal.tracking.show.send_reply"), class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <p><%= link_to t(".back"), portal_my_cases_path %></p>
</div>
