<%= form_with model: deal, class: "form" do |f| %>
  <%= render "shared/form_errors", record: deal %>

  <div class="form-row <%= "field-error" if deal.errors[:name].any? %>">
    <%= f.label :name, t("deals.fields.name") %>
    <%= f.text_field :name, required: true %>
    <% deal.errors[:name].each do |msg| %><p class="field-error-message"><%= msg %></p><% end %>
  </div>

  <% if deal.new_record? %>
    <div class="form-row">
      <%= f.label :pipeline_id, t("deals.fields.pipeline") %>
      <%= f.collection_select :pipeline_id, Pipeline.active.order(:position, :id), :id, :name %>
      <p class="form-hint"><%= t("deals.form.pipeline_hint") %></p>
    </div>
  <% else %>
    <div class="form-row">
      <%= f.label :pipeline_stage_id, t("deals.fields.stage") %>
      <%= f.collection_select :pipeline_stage_id, deal.pipeline.pipeline_stages.order(:position), :id, :name %>
    </div>
  <% end %>

  <div class="form-row">
    <%= f.label :owner_id, t("deals.fields.owner") %>
    <%= f.collection_select :owner_id, User.active.staff.order(:name), :id, :name,
          include_blank: t("forms.none") %>
  </div>

  <div class="form-row">
    <%= f.label :contact_id, t("deals.fields.contact") %>
    <%= f.collection_select :contact_id, Contact.order(:name), :id, :name,
          include_blank: t("forms.none") %>
  </div>

  <div class="form-row">
    <%= f.label :value, t("deals.fields.value") %>
    <%= f.number_field :value, step: "0.01", min: 0 %>
  </div>

  <div class="form-row">
    <%= f.label :expected_close_on, t("deals.fields.expected_close_on") %>
    <%= f.date_field :expected_close_on %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), deals_path, class: "btn" %>
  </div>
<% end %>
